{
  "manifest_version": 3,
  "name": "TrustLens Companion",
  "version": "0.1.0",
  "description": "Analyze selected suspicious text with a local TrustLens API before clicking.",
  "action": {
    "default_title": "TrustLens",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*/*"
  ]
}
